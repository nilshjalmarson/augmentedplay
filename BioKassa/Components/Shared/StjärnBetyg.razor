@* Klickbara stjärnor 1–5. Stoppar klicket från att bubbla upp till föräldrar. *@

<div class="stjarn-betyg" @onclick:stopPropagation="true">
    @for (int i = 1; i <= 5; i++)
    {
        var stjärna = i;
        <span class="stjarn-knapp @(stjärna <= Betyg ? "fylld" : "")"
              @onclick="() => SättBetyg(stjärna)"
              title="@stjärna stjärnor">
            ★
        </span>
    }
</div>

@code {
    [Parameter] public int Betyg { get; set; }
    [Parameter] public EventCallback<int> BetygChanged { get; set; }

    private async Task SättBetyg(int betyg)
    {
        Betyg = betyg;
        await BetygChanged.InvokeAsync(betyg);
    }
}
